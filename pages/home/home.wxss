/* pages/home/home.wxss */
page{
  background-color: #ececec;
}
.orderbox{
  height: 25vh;
  width: 90vw;
}
.title{
  font-size: 2em;
  display: block;
}
.prop{
  font-size: 0.8em;
  color: #575757;
}
.orderbox-left{
  width: 38vw;
  height: 80%;
  padding: 25rpx;
  float: left;
  border-radius: 18rpx;
  background-color: #fff;
}
.orderbox-right{
  float: right;
  width: 40vw;
  height: 80%;
  display: flex;
  flex-direction: column;
}
.orderbox-right view{
  border-radius: 18rpx;
  background-color: #fff;
  flex: 1;
  padding: 18rpx;
}
.charge{
  margin-bottom: 45rpx;
}